# Koyeb / production — set these in the service dashboard (do not commit real values).

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Managed Postgres (Neon, Koyeb Postgres, etc.)
DB_URL=jdbc:postgresql://host:5432/wot
DB_USER=
DB_PASSWORD=

# Your Vercel frontend URL (comma-separated for preview + production)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Ephemeral disk on free tiers — uploads reset on redeploy unless you add persistent storage
WOT_UPLOAD_DIR=/tmp/wot-uploads

# JWT signing secret — generate a random string of at least 32 characters
WOT_JWT_SECRET=
WOT_JWT_EXPIRY_HOURS=168
